{
    "name": "personal-website",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && biome check && pnpm stylelint -c .stylelintrc.json src/**/*.{css,svelte}",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "check:fix": "svelte-kit sync && biome check --fix && pnpm stylelint -c .stylelintrc.json src/**/*.{css,svelte} --fix",
        "lint": "biome lint"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
