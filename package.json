        "@iconify-json/material-symbols": "^1.2.81",
        "@inlang/paraglide-js": "2.20.2",
        "@melt-ui/pp": "^0.3.2",
        "@melt-ui/svelte": "^0.86.6",
        "@portaljs/remark-callouts": "^1.0.5",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/enhanced-img": "^0.11.0",
        "@sveltejs/kit": "^2.68.0",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "@types/culori": "^4.0.1",
        "@types/remark-abbr": "^1.4.4",
        "browserslist": "^4.28.4",
        "lightningcss": "^1.32.0",
        "marked": "^18.0.5",
        "mdsvex": "^0.12.7",
        "postcss-html": "^1.8.1",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-slug": "^6.0.0",
        "remark-abbr": "^1.4.2",
        "remark-github": "^12.0.0",
        "sharp": "^0.35.2",
        "shiki": "^4.3.0",
        "stylelint": "^17.14.0",
        "stylelint-config-clean-order": "^10.0.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^8.1.1",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "sveltekit-view-transition": "^0.5.3",
        "tslib": "^2.8.1",
